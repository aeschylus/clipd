{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipd",
  "version": "0.2.0",
  "identifier": "ai.clipd.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "clipd-panel",
        "title": "clipd",
        "width": 480,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "active",
          "radius": 12
        }
      }
    ],
    "trayIcon": {
      "id": "tray",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "clipd — clipboard history"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": {
        "LSUIElement": "1",
        "NSClipboardUsageDescription": "clipd stores your clipboard history locally.",
        "NSAppleEventsUsageDescription": "clipd uses AppleEvents to detect the source app when you copy text."
      },
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": [],
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "global-shortcut": {
      "shortcuts": {}
    }
  }
}
